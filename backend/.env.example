# Tarsight 测试框架环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# Supabase 配置
# ============================================
# Supabase 项目 URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥
SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (用于绕过 RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# 项目配置
# ============================================
# 目标项目 ID (用于查询特定项目的测试用例)
TARGET_PROJECT=your-project-id

# ============================================
# API 测试配置
# ============================================
# 测试 API 基础 URL
BASE_URL=https://t-stream-iq.tarsv.com

# API 访问 Token (用于测试认证)
API_TOKEN=your-api-token

# ============================================
# 数据源配置
# ============================================
# 测试数据源 (csv | supabase)
DATA_SOURCE=supabase

# ============================================
# 测试执行配置
# ============================================
# JSON 记录开关 (true | false)
JSON_RECORDING=true

# JSON 结果文件路径 (可选，默认自动生成)
# TARSIGHT_JSON_RESULTS_FILE=reports/test_results.json

# 执行名称 (可选，默认自动生成)
# EXECUTION_NAME=测试执行

# ============================================
# 报告配置
# ============================================
# 报告输出目录
REPORTS_DIR=reports

# Allure 结果目录
ALLURE_RESULTS_DIR=reports/allure-results

# ============================================
# 日志配置
# ============================================
# 日志级别 (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
