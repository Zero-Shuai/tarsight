# Tarsight Dashboard 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ============================================
# Next.js 环境变量
# ============================================
NODE_ENV=development

# ============================================
# Supabase 配置
# ============================================
# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (服务端使用，请保密!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 项目 ID (用于多项目隔离)
NEXT_PUBLIC_PROJECT_ID=your-project-id

# ============================================
# Python 测试执行环境配置
# ============================================
# Python 项目根目录 (绝对路径)
# 本地开发示例: /Users/username/WorkSpace/Tarsight/supabase_version
# 生产环境示例: /app/tarsight/supabase_version
PROJECT_ROOT=/Users/zhangshuai/WorkSpace/Tarsight/supabase_version

# Python 解释器路径 (虚拟环境中的 Python)
# 本地开发示例: /Users/username/WorkSpace/Tarsight/supabase_version/.venv/bin/python
# 生产环境示例: /usr/bin/python3
PYTHON_PATH=/Users/zhangshuai/WorkSpace/Tarsight/supabase_version/.venv/bin/python

# ============================================
# 应用配置
# ============================================
# 应用基础 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# 可选配置
# ============================================
# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info

# API 超时时间 (毫秒)
API_TIMEOUT=300000
