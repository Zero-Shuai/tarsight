# ============================================
# Tarsight Docker 部署环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# 命令: cp docker-compose.env.example .env

# ============================================
# Supabase 配置（必需）
# ============================================
# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（公开）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（服务端使用，请保密!）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase 项目 URL（后端使用）
SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（后端使用）
SUPABASE_ANON_KEY=your-anon-key

# ============================================
# 项目配置
# ============================================
# 项目 ID
NEXT_PUBLIC_PROJECT_ID=8786c21f-7437-4a2d-8486-9365a382b38e

# 目标项目（后端使用）
TARGET_PROJECT=8786c21f-7437-4a2d-8486-9365a382b38e

# ============================================
# API 测试配置（后端使用）
# ============================================
# 测试 API 基础 URL
BASE_URL=https://t-stream-iq.tarsv.com

# API 访问 Token
API_TOKEN=your-api-token-here

# 数据源配置
DATA_SOURCE=supabase

# ============================================
# Docker 部署配置
# ============================================
# 前端端口映射（仅监听本机 127.0.0.1，供本地反向代理使用）
FRONTEND_PORT=25380

# 业务版本号（默认从这里控制，如 1.0 / 1.1 / 1.2）
APP_RELEASE_VERSION=1.0

# ============================================
# 日志配置（可选）
# ============================================
# Python 日志级别 (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# JSON 记录开关 (true | false)
JSON_RECORDING=true

# ============================================
# 获取 Supabase 配置的步骤：
# ============================================
# 1. 登录 https://supabase.com/dashboard
# 2. 选择你的项目
# 3. 进入 Settings → API
# 4. 复制以下信息:
#    - Project URL → SUPABASE_URL / NEXT_PUBLIC_SUPABASE_URL
#    - anon public key → SUPABASE_ANON_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY (保密!)
